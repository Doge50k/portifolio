---
// components/Hero.astro
---

<section id="inicio" class="relative pt-40 pb-20 px-6">
  <!-- Blobs decorativos -->
  <div class="blob blob-emerald top-20 left-10"></div>
  <div class="blob blob-cyan bottom-20 right-10"></div>

  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-16">
    <!-- Conteúdo textual -->
    <div class="md:w-3/5 text-center md:text-left">
      <div class="inline-block px-4 py-1.5 rounded-full glass border border-emerald-500/20 text-emerald-400 text-xs font-bold mb-6 tracking-widest uppercase">
        Unidade de Negócio & Desenvolvimento
      </div>
      <h1 class="text-5xl md:text-7xl font-extrabold mb-8 leading-[1.1]">
        Transformando problemas em <span class="text-gradient">soluções</span> através da tecnologia.
      </h1>
      <p class="text-lg text-gray-400 mb-10 max-w-xl leading-relaxed">
        Ajudo sua empresa a atender melhor, ganhar tempo e organizar a operação com sistemas feitos para o seu dia a dia.
      </p>
      <div class="flex flex-col sm:flex-row gap-5">
        <a
          href="https://wa.me/5594991583532?text=Oi,%20Elias!%20Tenho%20um%20projeto%20e%20gostaria%20da%20sua%20consultoria."
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-white px-10 py-4 rounded-xl font-bold text-center hover:scale-105 transition"
        >
          Fale Comigo
        </a>
        <div class="flex items-center justify-center gap-3 px-6 py-4 glass rounded-xl border border-white/10 text-sm">
          <span class="w-3 h-3 bg-emerald-500 rounded-full animate-pulse"></span>
          Disponível para novos projetos (CNPJ Ativo)
        </div>
      </div>
    </div>

    <!-- Imagem -->
    <div class="md:w-2/5 relative">
      <div class="absolute -inset-4 bg-gradient-to-r from-emerald-500 to-cyan-500 rounded-3xl opacity-20 blur-2xl"></div>
      <div class="relative glass rounded-3xl overflow-hidden border border-white/10 aspect-[4/5]">
        <img
          src="/images/perfil.png"
          alt="Elias Perfil"
          class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
        />
        <!-- Watermark Name -->
        <div class="absolute bottom-4 right-4 text-white/40 text-sm font-semibold tracking-widest">
          ELIAS
        </div>
      </div>
    </div>
  </div>
</section>
