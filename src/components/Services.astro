---
// components/Services.astro

interface Service {
  icon: string;
  title: string;
  description: string;
  iconBg: string;
  iconColor: string;
}

const services: Service[] = [
  {
    icon: 'fas fa-layer-group',
    title: 'Sistemas Web Sob Medida',
    description: 'Desenvolvimento de ferramentas que se moldam ao jeito que sua empresa trabalha. Tenha um sistema ágil, seguro e intuitivo, desenhado especificamente para otimizar a rotina do seu negócio.',
    iconBg: 'bg-emerald-500/10',
    iconColor: 'text-emerald-400',
  },
  {
    icon: 'fas fa-robot',
    title: 'Inteligência Artificial Aplicada',
    description: 'Integro o poder de LLMs para que seu sistema analise documentos, automatize o atendimento ao cliente e suporte decisões complexas em tempo real.',
    iconBg: 'bg-cyan-500/10',
    iconColor: 'text-cyan-400',
  },
  {
    icon: 'fas fa-server',
    title: 'Infraestrutura que não para',
    description: 'Garanta que sua plataforma esteja sempre no ar, pronta para atender milhares de usuários. Tecnologia de ponta para oferecer uma experiência contínua, segura e preparada para o crescimento.',
    iconBg: 'bg-white/5',
    iconColor: 'text-gray-300',
  },
];
---

<section id="servicos" class="py-24 px-6 relative">
  <div class="max-w-7xl mx-auto">
    <div class="mb-16">
      <h2 class="text-3xl font-bold mb-4">Como posso ajudar seu negócio hoje?</h2>
      <p class="text-gray-400 max-w-2xl">
        Não vendo apenas código. Entrego soluções que resolvem gargalos operacionais e criam novas fontes de receita.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        services.map((service) => (
          <div class="p-10 glass rounded-3xl card-hover border border-white/5 hover:border-emerald-500/20 transition">
            <div class={`w-14 h-14 ${service.iconBg} rounded-2xl flex items-center justify-center mb-8 ${service.iconColor} text-2xl`}>
              <i class={service.icon}></i>
            </div>
            <h3 class="text-xl font-bold mb-4">{service.title}</h3>
            <p class="text-gray-400 leading-relaxed text-sm">{service.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
