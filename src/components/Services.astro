---
// components/Services.astro

interface Service {
  icon: string;
  title: string;
  description: string;
  iconBg: string;
  iconColor: string;
}

const services: Service[] = [
  {
    icon: 'fas fa-layer-group',
    title: 'Sistema feito para a rotina da sua empresa',
    description: 'Crio sistemas que acompanham o jeito que sua empresa já trabalha, deixando a operação mais organizada, rápida e fácil de controlar.',
    iconBg: 'bg-emerald-500/10',
    iconColor: 'text-emerald-400',
  },
  {
    icon: 'fas fa-robot',
    title: 'Automação com IA para ganhar tempo',
    description: 'Uso IA para automatizar tarefas, responder mais rápido, analisar informações e ajudar sua empresa a tomar decisões com mais agilidade.',
    iconBg: 'bg-cyan-500/10',
    iconColor: 'text-cyan-400',
  },
  {
    icon: 'fas fa-server',
    title: 'Sistema estável e pronto para crescer',
    description: 'Seu sistema fica preparado para funcionar com segurança, atender bem e acompanhar o crescimento da empresa sem dor de cabeça.',
    iconBg: 'bg-white/5',
    iconColor: 'text-gray-300',
  },
];
---

<section id="servicos" class="py-24 px-6 relative">
  <div class="max-w-7xl mx-auto">
    <div class="mb-16">
      <h2 class="text-3xl font-bold mb-4">Como posso ajudar sua empresa?</h2>
      <p class="text-gray-400 max-w-2xl">
        Crio ferramentas que reduzem trabalho manual, organizam a rotina e ajudam sua empresa a crescer.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        services.map((service) => (
          <div class="p-10 glass rounded-3xl card-hover border border-white/5 hover:border-emerald-500/20 transition">
            <div class={`w-14 h-14 ${service.iconBg} rounded-2xl flex items-center justify-center mb-8 ${service.iconColor} text-2xl`}>
              <i class={service.icon}></i>
            </div>
            <h3 class="text-xl font-bold mb-4">{service.title}</h3>
            <p class="text-gray-400 leading-relaxed text-sm">{service.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
